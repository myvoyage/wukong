{
  "name": "wukong-baseline",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "greeting-001",
      "description": "Basic greeting response",
      "conversation": [
        {
          "role": "user",
          "content": "Hello! Who are you?"
        }
      ],
      "expected_pattern": "wukong",
      "min_response_len": 10
    },
    {
      "id": "math-001",
      "description": "Simple math calculation",
      "conversation": [
        {
          "role": "user",
          "content": "What is 2 + 2?"
        }
      ],
      "expected_pattern": "4",
      "min_response_len": 5
    },
    {
      "id": "tool-use-001",
      "description": "Agent should attempt to use tools when asked",
      "conversation": [
        {
          "role": "user",
          "content": "List the files in the current directory"
        }
      ],
      "expected_tools": ["list_files", "ls", "shell", "bash"],
      "min_response_len": 10
    }
  ]
}
